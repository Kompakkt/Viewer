{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": null,
  "categories": {},
  "rules": {
    "typescript/no-floating-promises": [
      "warn",
      {
        "ignoreIIFE": true,
        "ignoreVoid": true
      }
    ],
    "no-base-to-string": [
      "warn",
      {
        "ignoredTypeNames": ["ObjectID"]
      }
    ],
    "typescript/unbound-method": [
      "warn",
      {
        "ignoreStatic": true
      }
    ]
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "settings": {
    "jsx-a11y": {
      "polymorphicPropName": null,
      "components": {},
      "attributes": {}
    },
    "next": {
      "rootDir": []
    },
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "version": null,
      "componentWrapperFunctions": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    },
    "vitest": {
      "typecheck": false
    }
  },
  "env": {
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": ["test/**", "machine-translation.ts", "extract-translations.ts"]
}
